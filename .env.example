# .env.example — variables de entorno canónicas del arnés.
# Copia a .env (gitignored) solo si necesitas sobreescribir los defaults locales.
# El arnés está diseñado para arrancar SIN .env: estos son los defaults locales.

# --- Backend (Django) ---
# MVP: SQLite, sin Docker. Para migrar a Postgres, descomenta la línea postgres
# (y levanta el docker-compose de la raíz). Ver docs/conventions-backend.md.
DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgres://harness:harness@localhost:5432/harness   # futuro (docker-compose)
REDIS_URL=redis://localhost:6379/0                                 # solo si corres Celery; no requerido en MVP
# Orígenes permitidos para CORS (frontend de Next en dev). Separados por coma.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Frontend (Next.js) ---
# URL del backend que consume el cliente tipado (src/lib/api/client.ts).
NEXT_PUBLIC_API_URL=http://localhost:8000
