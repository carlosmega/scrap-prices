{
  "openapi": "3.1.0",
  "info": {
    "title": "ConstruScan API",
    "version": "0.1.0",
    "description": "API de ConstruScan (Django Ninja)."
  },
  "paths": {
    "/api/health": {
      "get": {
        "operationId": "apps_core_api_health",
        "summary": "Health",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthOut"
                }
              }
            }
          }
        },
        "description": "Estado del servicio. Estático, no toca la DB.",
        "tags": [
          "core"
        ]
      }
    },
    "/api/zones": {
      "get": {
        "operationId": "apps_geo_api_listar_zonas",
        "summary": "Listar Zonas",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ZoneOut"
                  },
                  "title": "Response",
                  "type": "array"
                }
              }
            }
          }
        },
        "description": "Lista las zonas activas ordenadas por nombre.",
        "tags": [
          "geo"
        ]
      }
    },
    "/api/zones/resolve": {
      "post": {
        "operationId": "apps_geo_api_resolver_zona",
        "summary": "Resolver Zona",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ZoneOut"
                }
              }
            }
          }
        },
        "description": "Resuelve la zona activa más cercana al centroide. 404 si sin cobertura.",
        "tags": [
          "geo"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResolveIn"
              }
            }
          },
          "required": true
        }
      }
    },
    "/api/search": {
      "get": {
        "operationId": "apps_catalog_api_buscar",
        "summary": "Buscar",
        "parameters": [
          {
            "in": "query",
            "name": "q",
            "schema": {
              "title": "Q",
              "type": "string"
            },
            "required": true
          },
          {
            "in": "query",
            "name": "zone_id",
            "schema": {
              "title": "Zone Id",
              "type": "string"
            },
            "required": true
          },
          {
            "in": "query",
            "name": "sort",
            "schema": {
              "default": "price",
              "title": "Sort",
              "type": "string"
            },
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/SearchResultOut"
                  },
                  "title": "Response",
                  "type": "array"
                }
              }
            }
          }
        },
        "description": "Busca canónicos por `q` con su precio más fresco por retailer en la zona.\n\n404 si `zone_id` no existe o está inactiva (el service devuelve None).",
        "tags": [
          "catalog"
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "HealthOut": {
        "description": "Respuesta del endpoint de salud.",
        "properties": {
          "status": {
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status"
        ],
        "title": "HealthOut",
        "type": "object"
      },
      "ZoneOut": {
        "description": "Representación pública de una zona (subconjunto del modelo Zone).",
        "properties": {
          "id": {
            "title": "Id",
            "type": "string"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "slug": {
            "title": "Slug",
            "type": "string"
          },
          "state": {
            "title": "State",
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "slug",
          "state"
        ],
        "title": "ZoneOut",
        "type": "object"
      },
      "ResolveIn": {
        "description": "Coordenadas del usuario para resolver su zona más cercana.",
        "properties": {
          "lat": {
            "title": "Lat",
            "type": "number"
          },
          "lng": {
            "title": "Lng",
            "type": "number"
          }
        },
        "required": [
          "lat",
          "lng"
        ],
        "title": "ResolveIn",
        "type": "object"
      },
      "CanonicalProductRefOut": {
        "description": "Subconjunto público del producto canónico para el resultado de búsqueda.",
        "properties": {
          "id": {
            "title": "Id",
            "type": "string"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "category": {
            "title": "Category",
            "type": "string"
          },
          "unit": {
            "title": "Unit",
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "category",
          "unit"
        ],
        "title": "CanonicalProductRefOut",
        "type": "object"
      },
      "PriceByRetailerOut": {
        "description": "Precio más fresco de un retailer para un canónico en una zona.\n\n`price`/`captured_at` son None cuando el retailer no tiene observación en la\nzona (entonces `is_available=False`). `price` se serializa como string del\nDecimal para no perder exactitud monetaria (PRD §8).",
        "properties": {
          "retailer": {
            "$ref": "#/components/schemas/RetailerRefOut"
          },
          "retailer_product_id": {
            "title": "Retailer Product Id",
            "type": "string"
          },
          "price": {
            "anyOf": [
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Price"
          },
          "currency": {
            "default": "MXN",
            "title": "Currency",
            "type": "string"
          },
          "is_available": {
            "default": false,
            "title": "Is Available",
            "type": "boolean"
          },
          "captured_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Captured At"
          },
          "url": {
            "title": "Url",
            "type": "string"
          }
        },
        "required": [
          "retailer",
          "retailer_product_id",
          "url"
        ],
        "title": "PriceByRetailerOut",
        "type": "object"
      },
      "RetailerRefOut": {
        "description": "Referencia mínima a un retailer dentro de un precio.",
        "properties": {
          "slug": {
            "title": "Slug",
            "type": "string"
          },
          "name": {
            "title": "Name",
            "type": "string"
          }
        },
        "required": [
          "slug",
          "name"
        ],
        "title": "RetailerRefOut",
        "type": "object"
      },
      "SearchResultOut": {
        "description": "Un producto canónico matcheado con sus precios por retailer en la zona.",
        "properties": {
          "canonical_product": {
            "$ref": "#/components/schemas/CanonicalProductRefOut"
          },
          "prices": {
            "items": {
              "$ref": "#/components/schemas/PriceByRetailerOut"
            },
            "title": "Prices",
            "type": "array"
          }
        },
        "required": [
          "canonical_product",
          "prices"
        ],
        "title": "SearchResultOut",
        "type": "object"
      }
    }
  },
  "servers": []
}