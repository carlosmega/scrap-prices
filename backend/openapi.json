{
  "openapi": "3.1.0",
  "info": {
    "title": "ConstruScan API",
    "version": "0.1.0",
    "description": "API de ConstruScan (Django Ninja)."
  },
  "paths": {
    "/api/health": {
      "get": {
        "operationId": "apps_core_api_health",
        "summary": "Health",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthOut"
                }
              }
            }
          }
        },
        "description": "Estado del servicio. Estático, no toca la DB.",
        "tags": [
          "core"
        ]
      }
    },
    "/api/zones": {
      "get": {
        "operationId": "apps_geo_api_listar_zonas",
        "summary": "Listar Zonas",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ZoneOut"
                  },
                  "title": "Response",
                  "type": "array"
                }
              }
            }
          }
        },
        "description": "Lista las zonas activas ordenadas por nombre.",
        "tags": [
          "geo"
        ]
      }
    },
    "/api/retailers": {
      "get": {
        "operationId": "apps_geo_api_listar_retailers",
        "summary": "Listar Retailers",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/RetailerOut"
                  },
                  "title": "Response",
                  "type": "array"
                }
              }
            }
          }
        },
        "description": "Lista todos los retailers (incluye inactivos) ordenados por nombre.",
        "tags": [
          "geo"
        ]
      }
    },
    "/api/zones/resolve": {
      "post": {
        "operationId": "apps_geo_api_resolver_zona",
        "summary": "Resolver Zona",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ZoneOut"
                }
              }
            }
          }
        },
        "description": "Resuelve la zona activa más cercana al centroide. 404 si sin cobertura.",
        "tags": [
          "geo"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResolveIn"
              }
            }
          },
          "required": true
        }
      }
    },
    "/api/search": {
      "get": {
        "operationId": "apps_catalog_api_buscar",
        "summary": "Buscar",
        "parameters": [
          {
            "in": "query",
            "name": "q",
            "schema": {
              "title": "Q",
              "type": "string"
            },
            "required": true
          },
          {
            "in": "query",
            "name": "zone_id",
            "schema": {
              "title": "Zone Id",
              "type": "string"
            },
            "required": true
          },
          {
            "in": "query",
            "name": "sort",
            "schema": {
              "default": "price",
              "title": "Sort",
              "type": "string"
            },
            "required": false
          },
          {
            "in": "query",
            "name": "live",
            "schema": {
              "default": "auto",
              "enum": [
                "auto",
                "never"
              ],
              "title": "Live",
              "type": "string"
            },
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchOut"
                }
              }
            }
          }
        },
        "description": "Busca `q` en la zona: canónicos comparados + crudos por tienda (F033).\n\nBREAKING F033: la respuesta pasa de lista a objeto (`SearchOut`). Con\n`live=auto` (default), si no hay datos frescos para `q`+zona el service\nconsulta ambos retailers EN VIVO (puede tardar hasta ~25 s), ingesta y\nresponde; `live=never` desactiva el vivo. 404 si `zone_id` no existe o\nestá inactiva (el service devuelve None).",
        "tags": [
          "catalog"
        ]
      }
    },
    "/api/products/{id}": {
      "get": {
        "operationId": "apps_catalog_api_detalle_producto",
        "summary": "Detalle Producto",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "schema": {
              "title": "Id",
              "type": "string"
            },
            "required": true
          },
          {
            "in": "query",
            "name": "zone_id",
            "schema": {
              "title": "Zone Id",
              "type": "string"
            },
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductDetailOut"
                }
              }
            }
          }
        },
        "description": "Detalle de un canónico en la zona: producto, precios actuales e historial.\n\n404 si el producto no existe/inactivo o si `zone_id` no existe/inactiva\n(el service devuelve None).",
        "tags": [
          "catalog"
        ]
      }
    },
    "/api/lists": {
      "get": {
        "operationId": "apps_lists_api_listar_listas",
        "summary": "Listar Listas",
        "parameters": [
          {
            "in": "header",
            "name": "x_session_key",
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X Session Key"
            },
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/UserListOut"
                  },
                  "title": "Response",
                  "type": "array"
                }
              }
            }
          }
        },
        "description": "Lista las listas de la sesión (`X-Session-Key`). 400 sin header.",
        "tags": [
          "lists"
        ]
      },
      "post": {
        "operationId": "apps_lists_api_crear_lista",
        "summary": "Crear Lista",
        "parameters": [
          {
            "in": "header",
            "name": "x_session_key",
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X Session Key"
            },
            "required": false
          }
        ],
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserListOut"
                }
              }
            }
          }
        },
        "description": "Crea una lista para la sesión. 400 sin header; 422 cuerpo inválido.",
        "tags": [
          "lists"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserListCreateIn"
              }
            }
          },
          "required": true
        }
      }
    },
    "/api/lists/{list_id}": {
      "get": {
        "operationId": "apps_lists_api_detalle_lista",
        "summary": "Detalle Lista",
        "parameters": [
          {
            "in": "path",
            "name": "list_id",
            "schema": {
              "title": "List Id",
              "type": "string"
            },
            "required": true
          },
          {
            "in": "header",
            "name": "x_session_key",
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X Session Key"
            },
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserListDetailOut"
                }
              }
            }
          }
        },
        "description": "Detalle de una lista de la sesión (ítems + subtotal/total). 400 sin header; 404 ajena.",
        "tags": [
          "lists"
        ]
      },
      "patch": {
        "operationId": "apps_lists_api_actualizar_lista",
        "summary": "Actualizar Lista",
        "parameters": [
          {
            "in": "path",
            "name": "list_id",
            "schema": {
              "title": "List Id",
              "type": "string"
            },
            "required": true
          },
          {
            "in": "header",
            "name": "x_session_key",
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X Session Key"
            },
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserListOut"
                }
              }
            }
          }
        },
        "description": "Actualiza nombre y/o zona de una lista de la sesión. 400 sin header; 404 si no es suya.",
        "tags": [
          "lists"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserListPatchIn"
              }
            }
          },
          "required": true
        }
      },
      "delete": {
        "operationId": "apps_lists_api_eliminar_lista",
        "summary": "Eliminar Lista",
        "parameters": [
          {
            "in": "path",
            "name": "list_id",
            "schema": {
              "title": "List Id",
              "type": "string"
            },
            "required": true
          },
          {
            "in": "header",
            "name": "x_session_key",
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X Session Key"
            },
            "required": false
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          }
        },
        "description": "Borra una lista de la sesión (sin body). 400 sin header; 404 si no es suya; 204 si ok.",
        "tags": [
          "lists"
        ]
      }
    },
    "/api/lists/{list_id}/items": {
      "post": {
        "operationId": "apps_lists_api_agregar_item",
        "summary": "Agregar Item",
        "parameters": [
          {
            "in": "path",
            "name": "list_id",
            "schema": {
              "title": "List Id",
              "type": "string"
            },
            "required": true
          },
          {
            "in": "header",
            "name": "x_session_key",
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X Session Key"
            },
            "required": false
          }
        ],
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserListItemOut"
                }
              }
            }
          }
        },
        "description": "Agrega un SKU con snapshot inmutable. 400 sin header; 404 lista/SKU; 422 sin precio.",
        "tags": [
          "lists"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserListItemCreateIn"
              }
            }
          },
          "required": true
        }
      }
    },
    "/api/lists/{list_id}/items/{item_id}": {
      "patch": {
        "operationId": "apps_lists_api_actualizar_item",
        "summary": "Actualizar Item",
        "parameters": [
          {
            "in": "path",
            "name": "list_id",
            "schema": {
              "title": "List Id",
              "type": "string"
            },
            "required": true
          },
          {
            "in": "path",
            "name": "item_id",
            "schema": {
              "title": "Item Id",
              "type": "string"
            },
            "required": true
          },
          {
            "in": "header",
            "name": "x_session_key",
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X Session Key"
            },
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserListItemOut"
                }
              }
            }
          }
        },
        "description": "Cambia la cantidad de un ítem (el snapshot no se toca). 400 sin header; 404; 422 cantidad.",
        "tags": [
          "lists"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserListItemPatchIn"
              }
            }
          },
          "required": true
        }
      },
      "delete": {
        "operationId": "apps_lists_api_eliminar_item",
        "summary": "Eliminar Item",
        "parameters": [
          {
            "in": "path",
            "name": "list_id",
            "schema": {
              "title": "List Id",
              "type": "string"
            },
            "required": true
          },
          {
            "in": "path",
            "name": "item_id",
            "schema": {
              "title": "Item Id",
              "type": "string"
            },
            "required": true
          },
          {
            "in": "header",
            "name": "x_session_key",
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X Session Key"
            },
            "required": false
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          }
        },
        "description": "Quita un ítem de la lista de la sesión (sin body). 400 sin header; 404; 204 si ok.",
        "tags": [
          "lists"
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "HealthOut": {
        "description": "Respuesta del endpoint de salud.",
        "properties": {
          "status": {
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status"
        ],
        "title": "HealthOut",
        "type": "object"
      },
      "ZoneOut": {
        "description": "Representación pública de una zona (subconjunto del modelo Zone).",
        "properties": {
          "id": {
            "title": "Id",
            "type": "string"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "slug": {
            "title": "Slug",
            "type": "string"
          },
          "state": {
            "title": "State",
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "slug",
          "state"
        ],
        "title": "ZoneOut",
        "type": "object"
      },
      "RetailerOut": {
        "description": "Representación de soporte/diagnóstico de un retailer (F018).\n\nExpone el modelo de pricing y el estado del scraper para que la UI/operador\nvea de un vistazo qué fuentes están activas/pausadas/no viables.",
        "properties": {
          "id": {
            "title": "Id",
            "type": "string"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "slug": {
            "title": "Slug",
            "type": "string"
          },
          "pricing_model": {
            "title": "Pricing Model",
            "type": "string"
          },
          "scraper_status": {
            "title": "Scraper Status",
            "type": "string"
          },
          "is_active": {
            "title": "Is Active",
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "name",
          "slug",
          "pricing_model",
          "scraper_status",
          "is_active"
        ],
        "title": "RetailerOut",
        "type": "object"
      },
      "ResolveIn": {
        "description": "Coordenadas del usuario para resolver su zona más cercana.",
        "properties": {
          "lat": {
            "title": "Lat",
            "type": "number"
          },
          "lng": {
            "title": "Lng",
            "type": "number"
          }
        },
        "required": [
          "lat",
          "lng"
        ],
        "title": "ResolveIn",
        "type": "object"
      },
      "CanonicalProductRefOut": {
        "description": "Subconjunto público del producto canónico para el resultado de búsqueda.\n\nF031: `mass_kg` (peso de una pieza canónica) es el factor de conversión que\npermite a la UI explicar la normalización; None si el canónico no es\nnormalizable. String Decimal por exactitud.",
        "properties": {
          "id": {
            "title": "Id",
            "type": "string"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "category": {
            "title": "Category",
            "type": "string"
          },
          "unit": {
            "title": "Unit",
            "type": "string"
          },
          "mass_kg": {
            "anyOf": [
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Mass Kg"
          }
        },
        "required": [
          "id",
          "name",
          "category",
          "unit"
        ],
        "title": "CanonicalProductRefOut",
        "type": "object"
      },
      "LiveRetailerStatusOut": {
        "description": "Cómo le fue a UN retailer en la corrida en vivo (F033).\n\n`detail` es un motivo breve legible (jamás un stacktrace): por qué se\nbloqueó, falló u omitió. `ok` con `items_found=0` significa \"consultado\ncon éxito pero sin hallazgos\".",
        "properties": {
          "retailer_slug": {
            "title": "Retailer Slug",
            "type": "string"
          },
          "status": {
            "enum": [
              "ok",
              "failed",
              "blocked",
              "skipped"
            ],
            "title": "Status",
            "type": "string"
          },
          "items_found": {
            "default": 0,
            "title": "Items Found",
            "type": "integer"
          },
          "detail": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Detail"
          }
        },
        "required": [
          "retailer_slug",
          "status"
        ],
        "title": "LiveRetailerStatusOut",
        "type": "object"
      },
      "LiveSearchInfoOut": {
        "description": "Info de la corrida en vivo que acompañó a la búsqueda (F033).",
        "properties": {
          "triggered": {
            "title": "Triggered",
            "type": "boolean"
          },
          "duration_ms": {
            "title": "Duration Ms",
            "type": "integer"
          },
          "retailers": {
            "items": {
              "$ref": "#/components/schemas/LiveRetailerStatusOut"
            },
            "title": "Retailers",
            "type": "array"
          }
        },
        "required": [
          "triggered",
          "duration_ms",
          "retailers"
        ],
        "title": "LiveSearchInfoOut",
        "type": "object"
      },
      "PriceByRetailerOut": {
        "description": "Precio más fresco de un retailer para un canónico en una zona.\n\n`price`/`captured_at` son None cuando el retailer no tiene observación en la\nzona (entonces `is_available=False`). `price` se serializa como string del\nDecimal para no perder exactitud monetaria (PRD §8).\n\nF031: `price` es el valor NATIVO del retailer (transparencia: \"listado a\n$X/ton\"); `sale_unit` es su unidad estructurada (`\"\"` = desconocida). La\ncomparación cross-retailer usa los campos NORMALIZADOS `price_per_piece`\n(titular de obra) y `price_per_kg` (base de orden/menor-precio). Cualquiera\nde los dos es None cuando no se puede normalizar (falta `mass_kg`, unidad\ndesconocida o sin precio en la zona). También como string Decimal.",
        "properties": {
          "retailer": {
            "$ref": "#/components/schemas/RetailerRefOut"
          },
          "retailer_product_id": {
            "title": "Retailer Product Id",
            "type": "string"
          },
          "price": {
            "anyOf": [
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Price"
          },
          "currency": {
            "default": "MXN",
            "title": "Currency",
            "type": "string"
          },
          "is_available": {
            "default": false,
            "title": "Is Available",
            "type": "boolean"
          },
          "captured_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Captured At"
          },
          "url": {
            "title": "Url",
            "type": "string"
          },
          "sale_unit": {
            "default": "",
            "title": "Sale Unit",
            "type": "string"
          },
          "price_per_piece": {
            "anyOf": [
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Price Per Piece"
          },
          "price_per_kg": {
            "anyOf": [
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Price Per Kg"
          }
        },
        "required": [
          "retailer",
          "retailer_product_id",
          "url"
        ],
        "title": "PriceByRetailerOut",
        "type": "object"
      },
      "RawRetailerResultOut": {
        "description": "Un hallazgo CRUDO de una tienda, aún sin matchear a un canónico (F033).\n\nEs un `RetailerProduct` sin `canonical_product` cuyo `raw_name` matchea `q`\n(acento-insensible), con su observación más fresca en la zona. El precio es\nNATIVO en la unidad del retailer (`sale_unit`, None = desconocida): NO es\ncomparable cross-retailer hasta curarse en Admin (matching manual, PRD D1).\n`price` va como float por contrato F033 (dato informativo, no monetario\nexacto como los Decimal de `PriceByRetailerOut`).",
        "properties": {
          "retailer_slug": {
            "title": "Retailer Slug",
            "type": "string"
          },
          "retailer_name": {
            "title": "Retailer Name",
            "type": "string"
          },
