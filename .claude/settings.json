{
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "Bash(./init.sh:*)",
      "Bash(docker compose:*)",
      "Bash(uv run:*)",
      "Bash(uv sync:*)",
      "Bash(pnpm:*)",
      "Bash(npx -y shadcn:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git init:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-feature.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/format-file.sh\""
          }
        ]
      }
    ]
  }
}
